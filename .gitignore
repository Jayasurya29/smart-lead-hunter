# =============================================================================
# SMART LEAD HUNTER - .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Environment Variables (SECRETS - NEVER COMMIT) ---
.env
.env.local
.env.production

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# --- Output Files (generated data) ---
output/*.csv
output/*.json
output/*.xlsx
!output/.gitkeep

# --- Learning Data (generated at runtime) ---
data/learnings/*.json
!data/learnings/.gitkeep

# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- Logs ---
*.log
logs/
enrichment_log.txt

# --- Backups ---
backups/

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini
nul

# --- Test artifacts ---
test_gold_urls.py
check_sources.py
test_source.py
htmlcov/
.coverage
.pytest_cache/

# --- Temp files ---
*.tmp
*.bak
*.oldb

# --- Container/OCI artifacts (Ollama, Docker) ---
blobs/
manifests/
celerybeat-schedule.*

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local