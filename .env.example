# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/smart_lead_hunter

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_URL=http://localhost:11434

#gemini api key
GEMINI_API_KEY=your-gemini-api-key-here

#hunter api key
HUNTER_API_KEY=your-hunter-api-key-here

#apollo api key
APOLLO_API_KEY=your-apollo-api-key-here

# Insightly
INSIGHTLY_API_KEY=
your-insightly-api-key-here

# Environment
ENVIRONMENT=development
# Authentication
API_AUTH_KEY=your-api-auth-key-here

# SMTP — used by OTP verification AND the pre-opening digest (HV-2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@jauniforms.com
SMTP_PASSWORD=your-smtp-app-password

# Pre-opening digest recipients (HV-2): comma-separated emails. The
# digest task runs each weekday at 9 AM and emails sales about leads
# crossing into the 6-12 month uniform procurement window. Leave
# blank to disable email send (the task still logs to stdout).
DIGEST_RECIPIENTS=sales@jauniforms.com,jay@jauniforms.com

# JWT secret — REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
